# GitHub App credentials. Either put the PEM at `private_key_path` in rex.config.yml,
# or paste it here (and set `private_key_env: GITHUB_APP_PRIVATE_KEY` in rex.config.yml).
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret you configured on the GitHub App.
REX_WEBHOOK_SECRET=

# Optional: override path to rex.config.yml.
# REX_CONFIG_PATH=./rex.config.yml
